# Enforce LF line endings for all text files on all platforms.
# Run `git add --renormalize .` after adding this file.
* text=auto eol=lf

# Explicitly mark binary files so git never converts them
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.svg text eol=lf
